# ══════════════════════════════════════════════════
#  ForgeMinds — Environment Configuration
#  Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════

# ─── Application ─────────────────────────────────
APP_ENV=development
APP_NAME=ForgeMinds
APP_VERSION=1.0.0
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ─── PostgreSQL ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forgeminds
POSTGRES_USER=forgeminds
POSTGRES_PASSWORD=forgeminds_dev

# ─── Neo4j ───────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=forgeminds_dev

# ─── Qdrant ──────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Redis ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── LLM (Free Tier) ────────────────────────────
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional OpenAI fallback (not required)
# OPENAI_API_KEY=

# ─── Authentication ──────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ─── Storage ─────────────────────────────────────
STORAGE_PATH=./storage/documents
